# Core Solana
RPC_URL=https://api.mainnet-beta.solana.com
PRIVATE_KEY_BASE58=your_wallet_private_key_base58
TARGET_WALLET=target_wallet_pubkey_to_copy
COMMITMENT=confirmed

# Yellowstone gRPC
YELLOWSTONE_ENDPOINT=https://your-yellowstone-endpoint:443
YELLOWSTONE_X_TOKEN=your-yellowstone-token

# Trading mode
QUOTE_MINT=So11111111111111111111111111111111111111112
COPY_AMOUNT_MODE=FIXED_QUOTE
FIXED_BUY_AMOUNT=0.1
SLIPPAGE_BPS=300
PRIORITY_FEE_LAMPORTS=10000

# Sell behavior
AUTO_SELL=true
TAKE_PROFIT_PCT=40
STOP_LOSS_PCT=20
POLL_INTERVAL_MS=7000

# Optional controls
DEX_ALLOWLIST=RAYDIUM,METEORA,PUMPSWAP,PUMPFUN
MIN_TARGET_BUY_AMOUNT=0

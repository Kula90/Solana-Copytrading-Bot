{
  "name": "solana-copytrading-bot",
  "version": "0.1.0",
  "description": "Solana copytrading bot using Yellowstone gRPC and multi-DEX execution",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "copytrading",
    "yellowstone",
    "raydium",
    "meteora",
    "pumpfun"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "@triton-one/yellowstone-grpc": "^4.0.1",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
